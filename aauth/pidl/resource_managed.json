{
  "$schema": "https://raw.githubusercontent.com/grokify/pidl/main/schema/pidl.schema.json",
  "protocol": {
    "id": "aauth-resource-managed",
    "name": "AAuth Resource-Managed Flow",
    "version": "1.0",
    "description": "AAuth resource-managed flow where resources challenge agents to obtain auth tokens from the Person Server",
    "category": "auth",
    "references": [
      {
        "name": "AAuth Protocol Draft",
        "url": "https://datatracker.ietf.org/doc/draft-hardt-oauth-aauth-protocol/"
      },
      {
        "name": "RFC 8693 Token Exchange",
        "url": "https://datatracker.ietf.org/doc/html/rfc8693"
      }
    ]
  },
  "entities": [
    {
      "id": "agent",
      "name": "Agent",
      "type": "agent",
      "description": "AI agent with cryptographic identity"
    },
    {
      "id": "resource",
      "name": "Resource Server",
      "type": "resource_server",
      "description": "Server hosting protected resources, requires auth tokens"
    },
    {
      "id": "person_server",
      "name": "Person Server",
      "type": "authorization_server",
      "description": "Issues auth tokens on behalf of humans who authorized agents"
    }
  ],
  "phases": [
    {
      "id": "initial_request",
      "name": "Initial Request",
      "description": "Agent attempts to access resource without auth token"
    },
    {
      "id": "challenge",
      "name": "Challenge",
      "description": "Resource returns WWW-Authenticate challenge"
    },
    {
      "id": "token_exchange",
      "name": "Token Exchange",
      "description": "Agent exchanges resource token at Person Server"
    },
    {
      "id": "authorized_request",
      "name": "Authorized Request",
      "description": "Agent accesses resource with auth token"
    }
  ],
  "flows": [
    {
      "from": "agent",
      "to": "resource",
      "action": "initial_request",
      "label": "HTTP Request + Signature (no auth token)",
      "mode": "request",
      "phase": "initial_request"
    },
    {
      "from": "resource",
      "to": "resource",
      "action": "verify_identity",
      "label": "Verify agent identity signature",
      "mode": "request",
      "phase": "initial_request"
    },
    {
      "from": "resource",
      "to": "agent",
      "action": "challenge",
      "label": "401 + WWW-Authenticate: AAuth realm=... ps=... resource_token=...",
      "mode": "response",
      "phase": "challenge",
      "annotations": [
        {
          "type": "info",
          "text": "Resource token contains agent JKT, scope, and resource URL"
        }
      ]
    },
    {
      "from": "agent",
      "to": "person_server",
      "action": "token_exchange",
      "label": "POST /token (grant_type=token-exchange, subject_token=resource_token)",
      "mode": "request",
      "phase": "token_exchange"
    },
    {
      "from": "person_server",
      "to": "person_server",
      "action": "verify_resource_token",
      "label": "Verify resource token + check agent authorization",
      "mode": "request",
      "phase": "token_exchange"
    },
    {
      "from": "person_server",
      "to": "agent",
      "action": "auth_token",
      "label": "Auth Token (aa-auth+jwt with cnf claim)",
      "mode": "response",
      "phase": "token_exchange",
      "annotations": [
        {
          "type": "security",
          "text": "Auth token bound to agent's public key via cnf claim"
        }
      ]
    },
    {
      "from": "agent",
      "to": "resource",
      "action": "authorized_request",
      "label": "HTTP Request + Signature + Authorization: Bearer <auth_token>",
      "mode": "request",
      "phase": "authorized_request"
    },
    {
      "from": "resource",
      "to": "resource",
      "action": "verify_auth",
      "label": "Verify signature + auth token + cnf binding",
      "mode": "request",
      "phase": "authorized_request"
    },
    {
      "from": "resource",
      "to": "agent",
      "action": "resource_response",
      "label": "Protected Resource",
      "mode": "response",
      "phase": "authorized_request"
    }
  ]
}
