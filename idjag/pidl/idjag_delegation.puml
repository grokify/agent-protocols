@startuml
title ID-JAG Delegation Flow (Human-to-Agent)

participant "Human User" as user
participant "Identity Provider" as idp
participant "AI Agent" as agent
participant "Assertion Issuer" as issuer
participant "Authorization Server" as auth_server
participant "JWKS Endpoint" as jwks
participant "Resource Server" as resource_server


== User Authentication ==
user -> idp: Authenticate (OAuth/OIDC/SAML)
idp --> user: Identity Verified + Session Established

== Delegation Setup ==
user -> agent: Request Agent Action
agent -> issuer: Request Delegated Assertion (user_id, agent_id)
issuer -> issuer: Create JWT: sub=user, act={sub: agent}
issuer -> issuer: Sign with Private Key (RS256/ES256)
issuer --> agent: Signed Delegated JWT Assertion

== Token Exchange ==
agent -> auth_server: POST /token (grant_type=token-exchange, subject_token=JWT)
auth_server -> jwks: GET /.well-known/jwks.json
jwks --> auth_server: JWK Set (Public Keys)
auth_server -> auth_server: Verify Signature + Validate Claims + Check Actor
auth_server -> auth_server: Apply Delegation Policies
auth_server -> auth_server: Issue Access Token (preserves act claim)
auth_server --> agent: 200 OK (access_token with sub + act, expires_in)

== Delegated Resource Access ==
agent -> resource_server: GET /api/calendar (Authorization: Bearer <token>)
resource_server -> resource_server: Validate Token + Extract sub (user) + Extract act (agent)
resource_server -> resource_server: Authorize: User has access + Agent allowed to act
resource_server --> agent: 200 OK (User's Protected Data)
agent --> user: Task Completed (Result Summary)

@enduml
