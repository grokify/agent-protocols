digraph Protocol {
    rankdir=LR;
    node [shape=box, style=rounded];
    edge [fontsize=10];
    label="ID-JAG Delegation Flow (Human-to-Agent)";
    labelloc=t;
    fontsize=14;

    user [label="Human User", shape=oval];
    idp [label="Identity Provider", shape=ellipse];
    agent [label="AI Agent", shape=hexagon];
    issuer [label="Assertion Issuer", shape=box3d];
    auth_server [label="Authorization Server", shape=ellipse];
    jwks [label="JWKS Endpoint", shape=box3d];
    resource_server [label="Resource Server", shape=box3d];

    user -> idp [label="Authenticate (OAuth/OIDC/SAML)"];
    idp -> user [label="Identity Verified + Session Established"];
    user -> agent [label="Request Agent Action"];
    agent -> issuer [label="Request Delegated Assertion (user_id, agent_id)"];
    issuer -> issuer [label="Create JWT: sub=user, act={sub: agent}\nSign with Private Key (RS256/ES256)"];
    issuer -> agent [label="Signed Delegated JWT Assertion"];
    agent -> auth_server [label="POST /token (grant_type=token-exchange, subject_token=JWT)"];
    auth_server -> jwks [label="GET /.well-known/jwks.json"];
    jwks -> auth_server [label="JWK Set (Public Keys)"];
    auth_server -> auth_server [label="Verify Signature + Validate Claims + Check Actor\nApply Delegation Policies\nIssue Access Token (preserves act claim)"];
    auth_server -> agent [label="200 OK (access_token with sub + act, expires_in)"];
    agent -> resource_server [label="GET /api/calendar (Authorization: Bearer <token>)"];
    resource_server -> resource_server [label="Validate Token + Extract sub (user) + Extract act (agent)\nAuthorize: User has access + Agent allowed to act"];
    resource_server -> agent [label="200 OK (User's Protected Data)"];
    agent -> user [label="Task Completed (Result Summary)"];
}
