digraph Protocol {
    rankdir=LR;
    node [shape=box, style=rounded];
    edge [fontsize=10];
    label="ID-JAG Simple Flow (Agent-Only)";
    labelloc=t;
    fontsize=14;

    agent [label="AI Agent", shape=hexagon];
    issuer [label="Assertion Issuer", shape=box3d];
    auth_server [label="Authorization Server", shape=ellipse];
    jwks [label="JWKS Endpoint", shape=box3d];
    resource_server [label="Resource Server", shape=box3d];

    agent -> issuer [label="Request Identity Assertion"];
    issuer -> issuer [label="Create JWT Claims (iss, sub, aud, exp)\nSign with Private Key (RS256/ES256)"];
    issuer -> agent [label="Signed JWT Assertion"];
    agent -> auth_server [label="POST /token (grant_type=token-exchange, subject_token=JWT)"];
    auth_server -> jwks [label="GET /.well-known/jwks.json"];
    jwks -> auth_server [label="JWK Set (Public Keys)"];
    auth_server -> auth_server [label="Verify Signature + Validate Claims (iss, aud, exp)\nIssue Access Token"];
    auth_server -> agent [label="200 OK (access_token, token_type=Bearer, expires_in)"];
    agent -> resource_server [label="GET /api/data (Authorization: Bearer <token>)"];
    resource_server -> jwks [label="Verify Access Token Signature"];
    jwks -> resource_server [label="Public Keys"];
    resource_server -> resource_server [label="Validate Token + Check Scope + Extract Subject"];
    resource_server -> agent [label="200 OK (Protected Data)"];
}
