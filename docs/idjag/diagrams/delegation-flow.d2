# ID-JAG Delegation Flow - Human-to-Agent Delegation
# Agent acts on behalf of a human user

direction: right

title: {
  label: ID-JAG Delegation Flow
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# Actors
human: {
  label: Human User\n(Alice)
  shape: person
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
}

agent: {
  label: Agent\n(Calendar Bot)
  shape: person
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Services
idp: {
  label: Identity Provider
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#F9A825"
}

auth-server: {
  label: Authorization Server
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"

  token-endpoint: {
    label: /token
    shape: rectangle
    style.fill: "#FFE0B2"
  }
}

resource-server: {
  label: Resource Server
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"

  api: {
    label: /calendar
    shape: rectangle
    style.fill: "#C8E6C9"
  }
}

# Flow
human -> idp: {
  label: "1. Authenticate"
  style.stroke: "#C2185B"
}

idp -> agent: {
  label: "2. Delegated Assertion\n   sub=user:alice\n   act={sub:agent:bot}"
  style.stroke: "#F9A825"
}

agent -> auth-server.token-endpoint: {
  label: "3. Token Exchange"
  style.stroke: "#1565C0"
}

auth-server.token-endpoint -> agent: {
  label: "4. Access Token\n   (with act claim)"
  style.stroke: "#E65100"
}

agent -> resource-server.api: {
  label: "5. API Request"
  style.stroke: "#1565C0"
}

resource-server.api -> agent: {
  label: "6. Alice's Calendar"
  style.stroke: "#2E7D32"
}

# JWT Structure Box
jwt-box: {
  label: |md
    **Delegated Assertion JWT**
    ```json
    {
      "iss": "https://idp.example.com",
      "sub": "user:alice",
      "aud": "https://auth.example.com",
      "act": {
        "sub": "agent:calendar-bot"
      },
      "iat": 1609459200,
      "exp": 1609459500
    }
    ```
  |
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  near: bottom-center
}
